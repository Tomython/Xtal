@{
    ViewData["Title"] = "Home";
}

<div class="container">
    <!-- Logo Video -->
    <video class="logo-video" autoplay loop muted width="240" height="120">
        <source src="~/videos/blackxtalvideo.mp4" type="video/mp4">
        Your browser does not support the video tag.
    </video>
    
    <!-- File Input -->
    <input type="file" id="audioFileInput" class="file-input" accept="audio/*" aria-label="Select audio file">
    
    <!-- Cover Art -->
    <img id="coverArt" class="cover-art" src="~/images/placeholder.png" alt="Album cover">
    
    <!-- Track Title -->
    <div id="trackTitle" class="track-title">Select an audio file to begin</div>
    
    <!-- Player Container -->
    <div id="player-container" class="player-container">
        <!-- Play/Pause Button -->
        <button id="playPause" class="btn" aria-label="Play or pause audio">Play</button>
        
        <!-- Seek Bar -->
        <div class="seek-container">
            <input type="range" id="seekBar" class="seek-bar" min="0" max="100" value="0" aria-label="Seek through audio">
            <div id="timeDisplay" class="time-display">00:00 / 00:00</div>
        </div>
        
        <!-- Speed Control -->
        <div class="speed-container">
            <span class="speed-label">Speed:</span>
            <input type="range" id="speedControl" class="speed-control" min="0.5" max="1.5" step="0.01" value="1" aria-label="Adjust playback speed">
            <span id="speedValue" class="speed-value">1.00×</span>
        </div>
    </div>
</div>

@section Scripts {
    <!-- External JavaScript library for metadata reading -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jsmediatags/3.9.5/jsmediatags.min.js"></script>
}
